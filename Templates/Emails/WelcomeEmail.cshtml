@model KiwiTaskAPI.Models.EmailModel
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f7f7f7;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            overflow: hidden;
        }

        .footer {
            height: 40px;
            background-color: #244034;
            padding: 10px 0;
        }

        .header {
            height: 60px;
            background-color: #244034;
            padding: 10px 0;
            text-align: center;
        }

            .header img, .footer img {
                width: auto;
                max-height: 40px;
                display: inline-block;
            }
        .content {
            background-color: #ffffff;
            padding: 50px;
        }

        h1 {
            color: #244034;
            font-size: 28px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }

            h1 img.icon {
                width: 30px;
                height: 30px;
                margin-right: 10px;
            }

        p {
            font-size: 16px;
            line-height: 1.6;
            color: #555555;
            margin-bottom: 20px;
        }

        blockquote {
            border-left: 4px solid #244034;
            padding-left: 10px;
            color: #777777;
            margin: 20px 0;
        }

        .btn {
            display: inline-block;
            background-color: #244034;
            color: #ffffff !important;
            padding: 10px 20px;
            border-radius: 5px;
            text-decoration: none;
            font-size: 16px;
        }

        .secondary {
            color: #244034;
        }

        .footer-text {
            font-size: 14px;
            color: #ffffff;
            background-color: #244034;
            text-align: center;
            margin-top: 20px;
            margin-bottom: 20px;
            padding: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <img src="@Model.HeaderImage" alt="Header Image">
        </div>
        <div class="content">
            <h1>
                Dear @Model.Name,
            </h1>
            <p>Welcome to @Model.CompanyName!</p>
            <p>We are thrilled to have you on board. Enjoy our services and feel free to reach out if you have any questions.</p>
            <p>Best regards,<br>Your <span class="secondary">@Model.CompanyName</span> Team</p>
            <a href="@Model.FrontUrl" class="btn">Learn More</a>
        </div>
        <div class="footer-text">
            This is an automated message. Please do not reply.
        </div>
    </div>
</body>
</html>
